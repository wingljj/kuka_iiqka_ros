<mujoco model="kuka_kr20_scene">

    <!-- meshdir resolves relative to THIS file's directory:
         models/ → ../../../../kuka/model/kuka_kr20/assets -->
    <compiler angle="radian" boundmass="0.001" boundinertia="0.001"
              meshdir="../../../../kuka/model/kuka_kr20/assets"/>

    <option timestep="0.004" gravity="0 0 -9.81" integrator="implicitfast"
            solver="Newton" iterations="100"/>

    <default>
        <default class="kuka">
            <joint axis="0 0 1"/>
            <default class="visual">
                <geom type="mesh" contype="0" conaffinity="0" group="1"/>
            </default>
            <default class="collision">
                <geom group="2"/>
            </default>
        </default>
    </default>

    <asset>
        <material name="kuka_black"
            rgba="0.054901960784313725 0.054901960784313725 0.06274509803921569 1"/>
        <material name="kuka_orange"
            rgba="0.9647058823529412 0.47058823529411764 0.1568627450980392 1"/>
        <material name="silver" rgba="0.7 0.7 0.7 1"/>

        <mesh name="base_link" file="base_link.stl" scale="0.001 0.001 0.001"/>
        <mesh name="link_1_1"  file="link_1_1.stl"  scale="0.001 0.001 0.001"/>
        <mesh name="link_2_1"  file="link_2_1.stl"  scale="0.001 0.001 0.001"/>
        <mesh name="link_3_1"  file="link_3_1.stl"  scale="0.001 0.001 0.001"/>
        <mesh name="link_4_1"  file="link_4_1.stl"  scale="0.001 0.001 0.001"/>
        <mesh name="link_5_1"  file="link_5_1.stl"  scale="0.001 0.001 0.001"/>
        <mesh name="link_6_1"  file="link_6_1.stl"  scale="0.001 0.001 0.001"/>
    </asset>

    <worldbody>
        <light pos="0 0 3" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
        <geom name="floor" type="plane" size="5 5 0.1" pos="0 0 0"
              rgba="0.8 0.9 0.8 1" contype="1" conaffinity="1"/>

        <!-- Mocap target driven by RSI endpoint to the corrected TCP pose.
             Initial pos = link_6_1 world position at zero-joint config
             (confirmed by mj_forward probe: [1.159, 0.0, 1.45] m). -->
        <body name="target" mocap="true" pos="1.159 0.0 1.45">
            <geom type="box" size="0.012 0.012 0.012" rgba="0 1 0 0.4"
                  contype="0" conaffinity="0"/>
        </body>

        <!-- Full KR20 arm — body hierarchy from kuka_kr20.xml unchanged. -->
        <body name="base_link" pos="0 0 0">
            <inertial pos="-0.02519167908195973 -0.0003512237430115979 0.14073533087089485"
                mass="2.7534689254296694"
                diaginertia="4.167631 5.193899 5.744846"/>
            <geom type="mesh" name="base_link_mesh" mesh="base_link" material="kuka_black"/>

            <body name="link_1_1" pos="0 0 0.274469">
                <inertial pos="0.04262669771195508 0.022539294966451077 0.16742328594359268"
                    mass="1.95025233840842"
                    diaginertia="3.903396 4.254089 4.101512"/>
                <joint name="joint_1" axis="0 0 1" limited="true"
                    range="-3.2288591161895095 3.2288591161895095"/>
                <geom type="mesh" name="link_1_1_mesh" pos="0 0 -0.274469"
                    mesh="link_1_1" material="kuka_orange"/>

                <body name="link_2_1" pos="0.16 -0.0948 0.245531">
                    <inertial pos="-0.006708726638690016 -0.08230603603988629 0.35023181950025006"
                        mass=".8242519331073362"
                        diaginertia="4.984932 5.021308 0.256664"/>
                    <joint name="joint_2" axis="0 -1 0" limited="true"
                        range="-3.2288591161895095 1.1344640137963142"/>
                    <geom type="mesh" name="link_2_1_mesh" pos="-0.16 0.0948 -0.52"
                        mesh="link_2_1" material="kuka_orange"/>

                    <body name="link_3_1" pos="0 -0.0203 0.78">
                        <inertial pos="0.03856241201011176 0.11370205937926676 0.07616220977557053"
                            mass="1.1562183723958658"
                            diaginertia="1.475083 2.199261 2.25828"/>
                        <joint name="joint_3" axis="0 1 0" limited="true"
                            range="-2.4085543677521746 3.0543261909900763"/>
                        <geom type="mesh" name="link_3_1_mesh" pos="-0.16 0.1151 -1.3"
                            mesh="link_3_1" material="kuka_orange"/>

                        <body name="link_4_1" pos="0.3 0.1151 0.15">
                            <inertial
                                pos="0.2794641231700052 0.005705547665961539 -1.1441231588804612e-06"
                                mass=".47719118331815324"
                                diaginertia="0.089286 1.63285 1.644056"/>
                            <joint name="joint_4" axis="1 0 0" limited="true"
                                range="-6.108652381980153 6.108652381980153"/>
                            <geom type="mesh" name="link_4_1_mesh" pos="-0.46 0 -1.45"
                                mesh="link_4_1" material="kuka_orange"/>

                            <body name="link_5_1" pos="0.56 0.0923 0">
                                <inertial
                                    pos="0.05739426005238135 -0.10605062717888086 -4.807006906970557e-06"
                                    mass=".10353274319603718"
                                    diaginertia="0.043336 0.032453 0.064603"/>
                                <joint name="joint_5" axis="0 1 0" limited="true"
                                    range="-2.2689280275926285 2.2689280275926285"/>
                                <geom type="mesh" name="link_5_1_mesh" pos="-1.02 -0.0923 -1.45"
                                    mesh="link_5_1" material="kuka_orange"/>

                                <body name="link_6_1" pos="0.139 -0.0923 0">
                                    <inertial
                                        pos="0.008129076502710442 -2.0340839963698945e-14 8.253251104872739e-05"
                                        mass="0.0020169644458108382"
                                        diaginertia="0.000104 5.5e-05 5.4e-05"/>
                                    <joint name="joint_6" axis="1 0 0" limited="true"
                                        range="-6.108652381980153 6.108652381980153"/>
                                    <geom type="mesh" name="link_6_1_mesh" pos="-1.159 0 -1.45"
                                        mesh="link_6_1" material="silver"/>

                                    <!-- Payload rigidly attached to link_6_1 (flange).
                                         pos="0 0 0.05": 50 mm along link_6_1 local +Z axis
                                         (at zero joints, +Z = world +Z = upward).
                                         FT sensor reads payload weight reaction. -->
                                    <body name="payload" pos="0 0 0.05">
                                        <inertial pos="0 0 0" mass="1.0"
                                            diaginertia="0.001 0.001 0.001"/>
                                        <site name="ft_site" pos="0 0 0" size="0.005"
                                            rgba="1 0 0 1"/>
                                        <geom name="payload_geom" type="box"
                                            size="0.02 0.02 0.03" rgba="0.9 0.7 0.2 1"/>
                                        <geom name="tip" type="sphere" size="0.01"
                                            pos="0.04 0 0" rgba="0.9 0.2 0.2 1"/>
                                    </body>
                                </body>
                            </body>
                        </body>
                    </body>
                </body>
            </body>
        </body>

        <!-- Wall at x=1.234 m: home tip outer edge is at 1.209 m (flange 1.159 +
             tip offset 0.04 + tip radius 0.01). Wall -X face is at 1.214 m,
             leaving ~5 mm clearance at home so a 10 mm push_into_wall produces
             contact, matching the existing test assertion. -->
        <body name="wall" pos="1.234 0 1.45">
            <geom name="wall_geom" type="box" size="0.02 0.3 0.3"
                rgba="0.7 0.7 0.7 1" contype="1" conaffinity="1"/>
        </body>
    </worldbody>

    <!-- Equality weld: constraint solver drives all 6 joints to satisfy this,
         giving implicit IK. Compliance matches the TCP scene (soft weld). -->
    <equality>
        <weld name="track" body1="link_6_1" body2="target"
              solref="0.008 1" solimp="0.99 0.999 0.001"/>
    </equality>

    <contact>
        <exclude body1="base_link" body2="link_1_1"/>
        <exclude body1="link_1_1"  body2="link_2_1"/>
        <exclude body1="link_2_1"  body2="link_3_1"/>
        <exclude body1="link_3_1"  body2="link_4_1"/>
        <exclude body1="link_4_1"  body2="link_5_1"/>
        <exclude body1="link_5_1"  body2="link_6_1"/>
        <exclude body1="link_6_1"  body2="payload"/>
    </contact>

    <sensor>
        <force  name="ft_force"  site="ft_site"/>
        <torque name="ft_torque" site="ft_site"/>
    </sensor>

</mujoco>
